{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/quest/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:username|src|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: username, src, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|variant|category|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: label, variant, category, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:category|sponsor|accent|muted|success|warning)$/]",
        "message": "<Badge> variant must be one of 'category' | 'sponsor' | 'accent' | 'muted' | 'success' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:fitness|social|food|community|nature)$/]",
        "message": "<Badge> category must be one of 'fitness' | 'social' | 'food' | 'community' | 'nature'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|variant|size|disabled|fullWidth|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: label, children, variant, size, disabled, fullWidth, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|link)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|active|count|onClick|key|ref|className|style|children)$/]",
        "message": "<CategoryChip> doesn't accept that prop. Declared props: label, active, count, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|type|label|error|disabled|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: placeholder, value, onChange, type, label, error, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|password|number|search)$/]",
        "message": "<Input> type must be one of 'text' | 'email' | 'password' | 'number' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|compact|key|ref|className|style|children)$/]",
        "message": "<LevelChip> doesn't accept that prop. Declared props: level, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuestCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|category|xpReward|distance|isSponsored|sponsorName|onClick|key|ref|className|style|children)$/]",
        "message": "<QuestCard> doesn't accept that prop. Declared props: title, description, category, xpReward, distance, isSponsored, sponsorName, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuestCard'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:fitness|social|food|community|nature)$/]",
        "message": "<QuestCard> category must be one of 'fitness' | 'social' | 'food' | 'community' | 'nature'."
      },
      {
        "selector": "JSXOpeningElement[name.name='XPBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:totalXp|key|ref|className|style|children)$/]",
        "message": "<XPBar> doesn't accept that prop. Declared props: totalXp."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Avatar": {
        "replaces": []
