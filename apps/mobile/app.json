{
  "expo": {
    "name": "Kuest",
    "slug": "kuest",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "kuest",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "31903b75-d817-4713-9211-a0cd8a167921"
      }
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kuest.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kuest uses your location to verify quest completions.",
        "NSCameraUsageDescription": "Kuest uses your camera to submit quest proof photos."
      }
    },
    "android": {
      "package": "com.kuest.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-camera",
        {
          "cameraPermission": "Kuest uses your camera for quest proof photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366F1"
        }
      ]
    ],
    "owner": "rahil1"
  }
}
