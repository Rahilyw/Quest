# Supabase — copy real values from Supabase Dashboard → Connect dialog
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Same URL + publishable key for browser auth (password reset). Required for forgot-password flow.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Admin allowlist — comma-separated emails that can access the admin dashboard.
# In production, if this is empty ALL logins are denied.
# In development, if this is empty a warning is logged and all emails are allowed.
ADMIN_ALLOWED_EMAILS=you@example.com,co-founder@example.com

# Base URL for password-reset email links (defaults to http://localhost:3000 in dev)
# ADMIN_SITE_URL=https://admin.yourdomain.com
#
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs (add all):
#   http://localhost:3000/auth/confirm
#   http://localhost:3000/login/reset-password
#   http://localhost:3000/password-reset.html
